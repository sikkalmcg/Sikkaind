
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "firstName", "lastName", "createdAt", "updatedAt"]
    },
    "Plant": {
      "title": "Plant",
      "type": "object",
      "description": "Plant master data registry.",
      "properties": {
        "id": { "type": "string" },
        "plantCode": { "type": "string" },
        "plantName": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "stateCode": { "type": "string" },
        "postalCode": { "type": "string" },
        "address": { "type": "string" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "mobileNumbers": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["plantCode", "plantName"]
    },
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "Company hub registry.",
      "properties": {
        "id": { "type": "string" },
        "plantCode": { "type": "string" },
        "companyCode": { "type": "string" },
        "companyName": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" },
        "state": { "type": "string" },
        "stateCode": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" }
      },
      "required": ["companyCode", "companyName"]
    },
    "Vendor": {
      "title": "Vendor",
      "type": "object",
      "description": "Vendor master data registry.",
      "properties": {
        "id": { "type": "string" },
        "plantCodes": { "type": "array", "items": { "type": "string" } },
        "vendorName": { "type": "string" },
        "address": { "type": "string" },
        "mobile": { "type": "string" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" }
      },
      "required": ["vendorName"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "description": "Customer registry (Consignor/Consignee).",
      "properties": {
        "id": { "type": "string" },
        "customerCode": { "type": "string" },
        "plantCodes": { "type": "array", "items": { "type": "string" } },
        "customerType": { "type": "string", "enum": ["Consignor", "Consignee"] },
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["customerCode", "plantCodes", "customerName", "customerType", "city"]
    },
    "SalesOrder": {
      "title": "SalesOrder",
      "type": "object",
      "description": "Sales Order registry.",
      "properties": {
        "id": { "type": "string" },
        "plantCode": { "type": "string" },
        "saleOrder": { "type": "string" },
        "saleOrderDate": { "type": "string" },
        "consignor": { "type": "string" },
        "from": { "type": "string" },
        "consignee": { "type": "string" },
        "shipToParty": { "type": "string" },
        "destination": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "driverMobile": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "invoiceNumber": { "type": "string" },
              "ewaybillNumber": { "type": "string" },
              "product": { "type": "string" },
              "unit": { "type": "string" },
              "unitUom": { "type": "string" },
              "weight": { "type": "string" },
              "weightUom": { "type": "string" }
            }
          }
        }
      },
      "required": ["plantCode", "saleOrder", "saleOrderDate", "consignor"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/user_profiles/{userId}": { "schema": "UserProfile", "description": "User profile data." },
    "/users/{userId}/plants/{plantId}": { "schema": "Plant", "description": "User-owned plants." },
    "/users/{userId}/companies/{companyId}": { "schema": "Company", "description": "User-owned companies." },
    "/users/{userId}/vendors/{vendorId}": { "schema": "Vendor", "description": "User-owned vendors." },
    "/users/{userId}/customers/{customerId}": { "schema": "Customer", "description": "User-owned customers." },
    "/users/{userId}/sales_orders/{orderId}": { "schema": "SalesOrder", "description": "User-owned sales orders." }
  }
}
