
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "firstName", "lastName", "createdAt", "updatedAt"]
    },
    "UserRegistry": {
      "title": "UserRegistry",
      "type": "object",
      "description": "System User Management and Access Control.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "mobile": { "type": "string" },
        "plants": { "type": "array", "items": { "type": "string" } },
        "tcodes": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "username", "password", "plants", "tcodes"]
    },
    "Plant": {
      "title": "Plant",
      "type": "object",
      "description": "Plant master data.",
      "properties": {
        "id": { "type": "string" },
        "plantCode": { "type": "string" },
        "plantName": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "stateCode": { "type": "string" },
        "postalCode": { "type": "string" },
        "address": { "type": "string" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "mobileNumbers": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["plantCode"]
    },
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "Company hub.",
      "properties": {
        "id": { "type": "string" },
        "plantCodes": { "type": "array", "items": { "type": "string" } },
        "companyCode": { "type": "string" },
        "companyName": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" },
        "state": { "type": "string" },
        "stateCode": { "type": "string" },
        "postalCode": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "logo": { "type": "string" },
        "termsAndConditions": { "type": "array", "items": { "type": "string" }, "maxItems": 8 }
      },
      "required": ["companyCode", "companyName"]
    },
    "Vendor": {
      "title": "Vendor",
      "type": "object",
      "description": "Vendor master data.",
      "properties": {
        "id": { "type": "string" },
        "vendorCode": { "type": "string" },
        "plantCodes": { "type": "array", "items": { "type": "string" } },
        "vendorName": { "type": "string" },
        "vendorFirmName": { "type": "string" },
        "address": { "type": "string" },
        "mobile": { "type": "string" },
        "route": { "type": "string" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" }
      },
      "required": ["mobile", "address", "route"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "description": "Customer (Consignor/Consignee).",
      "properties": {
        "id": { "type": "string" },
        "customerCode": { "type": "string" },
        "plantCodes": { "type": "array", "items": { "type": "string" } },
        "customerType": { "type": "string", "enum": ["Consignor", "Consignee - Ship to Party"] },
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "postalCode": { "type": "string" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["customerCode", "plantCodes", "customerName", "customerType", "city"]
    },
    "SalesOrder": {
      "title": "SalesOrder",
      "type": "object",
      "description": "Sales Order.",
      "properties": {
        "id": { "type": "string" },
        "plantCode": { "type": "string" },
        "saleOrder": { "type": "string" },
        "saleOrderDate": { "type": "string" },
        "consignor": { "type": "string" },
        "from": { "type": "string" },
        "consignee": { "type": "string" },
        "shipToParty": { "type": "string" },
        "destination": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "driverMobile": { "type": "string" },
        "delayRemark": { "type": "string" },
        "lrNo": { "type": "string" },
        "lrDate": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "invoiceNumber": { "type": "string" },
              "ewaybillNumber": { "type": "string" },
              "product": { "type": "string" },
              "unit": { "type": "string" },
              "unitUom": { "type": "string" },
              "weight": { "type": "string" },
              "weightUom": { "type": "string" }
            }
          }
        }
      },
      "required": ["plantCode", "saleOrder", "consignor"]
    },
    "Trip": {
      "title": "Trip",
      "type": "object",
      "description": "Logistics Trip.",
      "properties": {
        "id": { "type": "string" },
        "tripId": { "type": "string" },
        "saleOrderId": { "type": "string" },
        "saleOrderNumber": { "type": "string" },
        "plantCode": { "type": "string" },
        "shipToParty": { "type": "string" },
        "route": { "type": "string" },
        "assignWeight": { "type": "number" },
        "vehicleType": { "type": "string", "enum": ["OWN FLEET", "CONTRACT", "MARKET VEHICLE"] },
        "vehicleNumber": { "type": "string" },
        "driverMobile": { "type": "string" },
        "vendorName": { "type": "string" },
        "rate": { "type": "number" },
        "freightAmount": { "type": "number" },
        "isFixedRate": { "type": "boolean" },
        "delayRemark": { "type": "string" },
        "status": { "type": "string", "enum": ["LOADING", "IN-TRANSIT", "ARRIVED", "POD", "REJECTION", "CLOSED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tripId", "saleOrderId", "vehicleNumber", "status"]
    },
    "PublicTracking": {
      "title": "PublicTracking",
      "type": "object",
      "description": "Simplified node for public tracking queries.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "trip"] },
        "status": { "type": "string" },
        "reference": { "type": "string" },
        "delayRemark": { "type": "string" },
        "details": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/user_profiles/{userId}": { "schema": "UserProfile", "description": "User profile data." },
    "/user_registry/{userId}": { "schema": "UserRegistry", "description": "System Authorization." },
    "/users/{userId}/plants/{plantId}": { "schema": "Plant", "description": "User-owned plants." },
    "/users/{userId}/companies/{companyId}": { "schema": "Company", "description": "User-owned companies." },
    "/users/{userId}/vendors/{vendorId}": { "schema": "Vendor", "description": "User-owned vendors." },
    "/users/{userId}/customers/{customerId}": { "schema": "Customer", "description": "User-owned customers." },
    "/users/{userId}/sales_orders/{orderId}": { "schema": "SalesOrder", "description": "User-owned sales orders." },
    "/users/{userId}/trips/{tripId}": { "schema": "Trip", "description": "User-owned trip." },
    "/public_orders/{orderNo}": { "schema": "PublicTracking", "description": "Public searchable order nodes." },
    "/public_trips/{tripId}": { "schema": "PublicTracking", "description": "Public searchable trip nodes." }
  }
}
