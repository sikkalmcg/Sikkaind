
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /user_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Comprehensive rule for all user-owned registries
    match /users/{userId}/{collectionName}/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Public tracking access via collection group queries
    // Specifically allows read access for sales_orders and trips if they are accessed correctly
    match /{path=**}/sales_orders/{orderId} {
      allow read: if true; 
    }
    match /{path=**}/trips/{tripId} {
      allow read: if true;
    }
  }
}
