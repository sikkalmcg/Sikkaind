
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /user_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Comprehensive rule for all user-owned registries (plants, companies, vendors, customers, sales_orders)
    // This pattern ensures that list operations on these collections are correctly permitted for the owner.
    match /users/{userId}/{collectionName}/{docId} {
      allow read, write: if isOwner(userId);
    }
  }
}
