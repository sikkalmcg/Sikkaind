rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // HELPER FUNCTIONS (Registry Core)
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is an administrator.
     * Includes system admin emails and role-based registry check.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sikkaind.admin@sikka.com' || 
        request.auth.token.email == 'sikkalmcg@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    /**
     * Checks if the user is the owner of the document based on the path ID.
     */
    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || request.auth.token.email == userId);
    }

    function isRecordOwner(recordOwnerId) {
      return isSignedIn() && request.auth.uid == recordOwnerId;
    }

    function isExistingDoc() {
      return resource != null;
    }

    // --- Data Integrity Helpers ---
    
    function isCreatingOwnProfile(authUserId) {
      return request.resource.data.authUserId == authUserId;
    }

    function isMaintainingProfileId() {
      return request.resource.data.authUserId == resource.data.authUserId;
    }
    
    function isCreatingOwnRecord(authUserId) {
      return request.resource.data.employeeId == authUserId;
    }

    function isMaintainingRecordId() {
      return request.resource.data.employeeId == resource.data.employeeId;
    }

    // ------------------------------------------------------------------------
    // CORE REGISTRY RULES
    // ------------------------------------------------------------------------

    // --- SECURITY & ADMIN PLANTS ---

    match /roles_admin/{authUserId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();

      // Authorized Notification Registry Access
      match /notifications/{notifId} {
        allow read, list: if isOwner(userId) || isAdmin();
        allow create, update: if isSignedIn(); 
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // --- LOGISTICS MASTER DATA ---

    match /logistics_plants/{plantId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /carriers/{carrierId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /fuel_pumps/{pumpId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /logistics_parties/{partyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /material_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- MISSION PARTITIONED DATA (Plants Hierarchy) ---
    // Standardizing to recursive wildcard to allow collection listing (trips, shipments, etc.)
    match /plants/{plantId}/{allSubPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Global flat collections (for legacy sync or cross-plant views)
    match /trips/{tripId} {
      allow read, write: if isSignedIn();
    }

    match /vehicleEntries/{entryId} {
      allow read, write: if isSignedIn();
    }

    // --- HR & ATTENDANCE NODES ---

    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /holidays/{holidayId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /employees/{authUserId} {
      allow get: if isOwner(authUserId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(authUserId) && isCreatingOwnProfile(authUserId);
      allow update: if (isOwner(authUserId) || isAdmin()) && isExistingDoc() && isMaintainingProfileId();
      allow delete: if isAdmin() && isExistingDoc();

      match /attendanceRecords/{recordId} {
        allow get, list: if isOwner(authUserId) || isAdmin();
        allow create: if isOwner(authUserId) && isCreatingOwnRecord(authUserId);
        allow update: if (isOwner(authUserId) || isAdmin()) && isExistingDoc() && isMaintainingRecordId();
        allow delete: if (isOwner(authUserId) || isAdmin()) && isExistingDoc();
      }
    }

    match /anomalyFlags/{flagId} {
      allow get: if isAdmin() || (isExistingDoc() && isRecordOwner(resource.data.employeeId));
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // --- SYSTEM AUDIT & ARCHIVE ---

    match /activity_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /recycle_bin/{itemId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /gps_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- GLOBAL OVERRIDE ---
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}