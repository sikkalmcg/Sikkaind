rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MISSION REGISTRY SECURITY POLICY
     * Everyone who is authenticated can read and write to the registry nodes.
     * This ensures mission continuity across all authorized lifting nodes.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Grant access to all mission-critical collections for authenticated operators
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Specific Node Access for Root Admin node
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sikkaind.admin@sikka.com' || 
        request.auth.token.email == 'sikkalmcg@gmail.com'
      );
    }
  }
}
