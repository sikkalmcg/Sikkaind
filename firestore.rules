
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /user_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User Registry: Allow users to access their own authorization profile
    match /user_registry/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/{collectionName}/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Public tracking access via optimized dedicated collections
    match /public_orders/{orderNo} {
      allow read: if true;
    }
    match /public_trips/{tripId} {
      allow read: if true;
    }
  }
}
