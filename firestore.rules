
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SYSTEM: TRIGGER REDEPLOY FOR PERMISSION REFRESH
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /user_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User Registry: Allow signed-in users to read/list and manage registry for SU01/02/03 modules
    // Recursive wildcard allows collection listing in SU03 and credential verification
    match /user_registry/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Shared Company Hub: Allow all authorized employees to access Sikka Industries shared data
    // Recursive wildcard ensures that listing collections (Plants, Orders, etc.) is permitted
    match /users/Sikkaind/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Private User Nodes: Maintained for individual profile-specific data if needed
    match /users/{userId}/{collectionName}/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Public tracking access via optimized dedicated collections
    // Allow read for everyone, but only signed-in employees can update tracking info
    match /public_orders/{orderNo} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /public_trips/{tripId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
