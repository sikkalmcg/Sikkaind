rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MISSION REGISTRY SECURITY POLICY v2.5
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // PUBLIC ACCESS NODE: Allow tracking resolution without login
    match /trips/{tripId} {
      allow read: if true;
    }
    match /plants/{plantId}/shipments/{shipmentId} {
      allow read: if true;
    }
    match /plants/{plantId}/trips/{tripId} {
      allow read: if true;
    }
    match /gps_settings/api_config {
      allow read: if true;
    }
    match /logistics_plants/{plantId} {
      allow read: if true;
    }

    // OPERATOR ACCESS NODE: Full control for authenticated staff
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Specific Node Access for Root Admin node
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sikkaind.admin@sikka.com' || 
        request.auth.token.email == 'sikkalmcg@gmail.com'
      );
    }
  }
}
