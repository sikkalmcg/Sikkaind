{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/tracking/layout,_N_T_/dashboard/tracking/[tripId]/layout,_N_T_/dashboard/tracking/[tripId]/page,_N_T_/dashboard/tracking/default"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/tracking/$d$tripId/__PAGE__",
    "/dashboard/tracking/$d$tripId",
    "/dashboard/tracking",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}