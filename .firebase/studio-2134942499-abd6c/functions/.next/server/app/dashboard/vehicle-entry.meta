    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/vehicle-entry/layout,_N_T_/dashboard/vehicle-entry/page,_N_T_/dashboard/vehicle-entry"
  },
